# Copy to .env.local and fill in. Never commit .env.local.

# Anthropic (Claude Sonnet 4.5) — optional. When unset the LLM stub in
# lib/anthropic.ts is used (Task 4b deferred per CLAUDE.md §12).
ANTHROPIC_API_KEY=

# Supabase (ap-southeast-2 Sydney, PostGIS enabled)
# NEXT_PUBLIC_* are shipped to the browser. Service role MUST stay server-only.
# Deviates from CLAUDE.md §4 (which lists SUPABASE_URL / SUPABASE_ANON_KEY)
# because Next.js exposes only NEXT_PUBLIC_-prefixed vars to client code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps Geocoding + Places Autocomplete — optional. When set, used
# for unit / apartment-level address resolution. When empty we fall back
# to OSM Nominatim (street-level only — no unit data for AU).
# Enable both APIs in your Google Cloud project:
#   - Geocoding API
#   - Places API
# Restrict the key by HTTP referrer (your Vercel domain) or by IP.
GOOGLE_GEOCODING_API_KEY=

# Debug: when true, the ArcGIS helper logs the full query URL.
NEXT_PUBLIC_DEBUG=false
